@model IEnumerable<WebApplication4.Models.Reward>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Reward_Name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Points_Required)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Reward_Description)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Reward_Name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Points_Required)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Reward_Description)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.Reward_ID }) |
            @Html.ActionLink("Details", "Details", new { id=item.Reward_ID }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.Reward_ID })
        </td>
    </tr>
}

</table>
