@model IEnumerable<WebApplication4.Models.CollectionOfficer>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Officer_Name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Officer_Surname)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Officer_Email)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Officer_PhoneNo)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Officer_Area)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Username)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Password)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Date_Registered)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Collection_Status)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Officer_Name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Officer_Surname)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Officer_Email)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Officer_PhoneNo)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Officer_Area)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Username)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Password)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Date_Registered)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Collection_Status)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.Officer_ID }) |
            @Html.ActionLink("Details", "Details", new { id=item.Officer_ID }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.Officer_ID })
        </td>
    </tr>
}

</table>
