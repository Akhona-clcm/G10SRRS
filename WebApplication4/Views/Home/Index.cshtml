@{
    ViewBag.Title = "Smart Recycling Rewards System";
}

<div class="jumbotron">
    <h1>Smart Recycling Rewards System</h1>
    <p class="lead">
        Recycle, earn rewards, and help your community become greener.
    </p>
</div>

<div class="row">
    <!-- Residents -->
    <div class="col-md-4">
        <h2>Residents</h2>
        <p>Manage resident profiles and recycling records.</p>
        <p>
            <a href="@Url.Action("Index", "Residents")" class="btn btn-primary">View Residents</a>
        </p>
    </div>

    <!-- Rewards -->
    <div class="col-md-4">
        <h2>Rewards</h2>
        <p>Redeem points for rewards.</p>
        <p>
            <a href="@Url.Action("Index", "Rewards")" class="btn btn-success">View Rewards</a>
        </p>
    </div>

    <!-- Community Rewards -->
    <div class="col-md-4">
        <h2>Community Rewards</h2>
        <p>View community achievements and prizes.</p>
        <p>
            <a href="@Url.Action("Index", "CommunityRewards")" class="btn btn-info">View Community Rewards</a>
        </p>
    </div>
</div>

<hr />

<div class="row">
    <!-- Collections -->
    <div class="col-md-4">
        <h2>Collections</h2>
        <p>Track collection schedules and statuses.</p>
        <p>
            <a href="@Url.Action("Index", "Collections")" class="btn btn-warning">View Collections</a>
        </p>
    </div>

    <!-- Leaderboard -->
    <div class="col-md-4">
        <h2>Leaderboard</h2>
        <p>See the top recyclers and communities.</p>
        <p>
            <a href="@Url.Action("Index", "Leaderboard")" class="btn btn-secondary">View Leaderboard</a>
        </p>
    </div>

    <!-- Badges -->
    <div class="col-md-4">
        <h2>Badges</h2>
        <p>View badges and achievements earned.</p>
        <p>
            <a href="@Url.Action("Index", "Badges")" class="btn btn-dark">View Badges</a>
        </p>
    </div>
</div>

<hr />

<div class="row">
    <!-- Admin Dashboard -->
    <div class="col-md-12">
        <h2>Admin Dashboard</h2>
        <p>Manage the entire Smart Recycling Rewards System.</p>
        <a href="@Url.Action("Index", "Admin")" class="btn btn-danger">Open Admin Dashboard</a>
    </div>
</div>